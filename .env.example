# Public website environment variables
# Copy to .env and fill in your values

# URL of the Vitality CRM backend API
VITE_API_URL=http://localhost:3001/api/public

# URL of the CRM staff portal (different domain)
VITE_CRM_URL=https://crm.vitalitywellmedspa.com

# Stripe publishable key (for gift card payments)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Google Maps embed key (for Contact page)
VITE_GOOGLE_MAPS_KEY=
